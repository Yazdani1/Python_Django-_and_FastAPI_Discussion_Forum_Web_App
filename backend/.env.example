# Django
DJANGO_SECRET_KEY=change-me-in-production-django-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# FastAPI
APP_ENV=development
APP_SECRET_KEY=change-me-in-production-fastapi-secret

# Database
DATABASE_URL=postgresql+asyncpg://forum_user:forum_password@db:5432/forum_db
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=forum_db
DATABASE_USER=forum_user
DATABASE_PASSWORD=forum_password

# JWT
JWT_SECRET_KEY=change-me-in-production-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Cookie
COOKIE_SECURE=False
COOKIE_SAMESITE=lax

# CORS
CORS_ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
